# Pin the public registry for this personal/GitHub repo.
# Overrides a corporate ~/.npmrc that defaults to Autodesk Artifactory.
registry=https://registry.npmjs.org/
@jsr:registry=https://npm.jsr.io/

# Do not inherit Artifactory auth for npmjs.org requests.
//registry.npmjs.org/:always-auth=false

fetch-retries=5
fetch-timeout=300000
network-concurrency=8
